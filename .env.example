NODE_ENV=development
APP_DOMAIN=core.buekwebsite.com
ACME_EMAIL=

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:5173
API_HOST_PORT=4000

# Database
POSTGRES_USER=buek
POSTGRES_PASSWORD=buek
POSTGRES_DB=buek_core
DATABASE_URL=postgresql://buek:buek@localhost:5432/buek_core?schema=public
POSTGRES_HOST_PORT=5432

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Domain modules are discovered dynamically and registered without changing AI Core.
BUEK_DOMAIN_MODULES=@buek/domain-manufacturing

# Web
# Leave empty for same-origin deployment through Nginx (/api).
VITE_API_URL=

# Docker web port. Use 5173 locally.
# In production with Caddy, use WEB_PORT=127.0.0.1:8080.
WEB_PORT=5173
