generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InstalledDomainModule {
  id        String   @id @default(cuid())
  moduleId  String   @unique
  name      String
  version   String
  status    String   @default("installed")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id            String              @id @default(cuid())
  name          String
  industry      String
  workspaces    Workspace[]
  users         User[]
  knowledge     KnowledgeDocument[]
  conversations Conversation[]
  modules       CompanyModule[]
  employees     Employee[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Workspace {
  id               String            @id @default(cuid())
  companyId        String
  slug             String            @unique
  name             String
  organization     String
  industry         String
  domain           String
  plant            String
  shift            String            @default("Shift A")
  moduleId         String            @default("manufacturing")
  knowledgeVersion String            @default("2026.07")
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  knowledge        KnowledgeDocument[]
  conversations    Conversation[]
  modules          CompanyModule[]
  plants           Plant[]
  employees        Employee[]
  issues           Issue[]
  workOrders       WorkOrder[]
  timeline         ActivityEvent[]
  sops             SopDocument[]
  graphEdges       GraphEdge[]
  sopRevisions     SopRevision[]
  engineeringReports EngineeringReport[]
  checklistRuns    OperatorChecklistRun[]
  memoryRecords    MemoryRecord[]
  agentActions     AgentAction[]
  businessRules    BusinessRule[]
  lessonsLearned   LessonLearned[]
  customerComplaints CustomerComplaint[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([companyId])
}

model User {
  id            String         @id @default(cuid())
  companyId     String
  workspaceId   String?
  email         String
  name          String?
  role          String         @default("member")
  password      String?
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([companyId, email])
  @@index([companyId])
  @@index([workspaceId])
}

model Plant {
  id           String           @id @default(cuid())
  workspaceId  String
  name         String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lines        ProductionLine[]
  kpiSnapshots KpiSnapshot[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workspaceId])
}

model ProductionLine {
  id        String    @id @default(cuid())
  plantId   String
  name      String
  plant     Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  machines  Machine[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([plantId])
}

model Machine {
  id         String             @id @default(cuid())
  lineId     String
  code       String
  name       String
  status     String             @default("running")
  line       ProductionLine     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  telemetry  MachineTelemetry[]
  issues     Issue[]
  workOrders WorkOrder[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([lineId, code])
  @@index([lineId])
}

model Employee {
  id             String      @id @default(cuid())
  companyId      String
  workspaceId    String
  name           String
  email          String
  role           String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownedIssues    Issue[]     @relation("IssueOwner")
  workOrders     WorkOrder[] @relation("WorkOrderEngineer")
  approvals      Approval[]  @relation("ApprovalDecider")
  sopRevisions   SopRevision[] @relation("SopSubmitter")
  reports        EngineeringReport[] @relation("ReportAuthor")
  approvedReports EngineeringReport[] @relation("ReportApprover")
  lessonsLearned LessonLearned[] @relation("LessonAuthor")
  customerComplaints CustomerComplaint[] @relation("ComplaintEngineer")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([companyId])
  @@index([workspaceId])
}

model SopDocument {
  id          String    @id @default(cuid())
  workspaceId String
  referenceId String
  title       String
  revision    String
  category    String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, referenceId])
  @@index([workspaceId])
}

model Issue {
  id            String         @id @default(cuid())
  workspaceId   String
  machineId     String?
  title         String
  description   String?
  status        String         @default("open")
  severity      String         @default("medium")
  progress      Int            @default(0)
  ownerId       String?
  dueAt         DateTime?
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  machine       Machine?       @relation(fields: [machineId], references: [id], onDelete: SetNull)
  owner         Employee?      @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  investigation Investigation?
  workOrders    WorkOrder[]
  reports       EngineeringReport[]
  lessonsLearned LessonLearned[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([workspaceId])
  @@index([machineId])
  @@index([ownerId])
  @@index([status])
}

model Investigation {
  id        String   @id @default(cuid())
  issueId   String   @unique
  status    String   @default("in_progress")
  progress  Int      @default(0)
  steps     Json
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkOrder {
  id          String    @id @default(cuid())
  workspaceId String
  number      String
  machineId   String?
  issueId     String?
  title       String
  reason      String
  risk        String    @default("medium")
  status      String    @default("pending_approval")
  engineerId  String?
  aiReview    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  machine     Machine?  @relation(fields: [machineId], references: [id], onDelete: SetNull)
  issue       Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  engineer    Employee? @relation("WorkOrderEngineer", fields: [engineerId], references: [id], onDelete: SetNull)
  approval    Approval?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, number])
  @@index([workspaceId])
  @@index([status])
}

model Approval {
  id          String    @id @default(cuid())
  workOrderId String    @unique
  status      String    @default("waiting")
  decidedById String?
  decidedAt   DateTime?
  notes       String?
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  decidedBy   Employee? @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KpiSnapshot {
  id         String   @id @default(cuid())
  plantId    String
  metric     String
  value      Float
  recordedAt DateTime
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, metric, recordedAt])
}

model MachineTelemetry {
  id         String   @id @default(cuid())
  machineId  String
  metric     String
  value      Float
  recordedAt DateTime
  machine    Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId, metric, recordedAt])
}

model ActivityEvent {
  id          String    @id @default(cuid())
  workspaceId String
  occurredAt  DateTime
  title       String
  detail      String?
  category    String
  entityType  String?
  entityId    String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
}

model GraphEdge {
  id          String    @id @default(cuid())
  workspaceId String
  fromType    String
  fromId      String
  relation    String
  toType      String
  toId        String
  label       String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, fromType, fromId])
  @@index([workspaceId, toType, toId])
}

model KnowledgeDocument {
  id          String            @id @default(cuid())
  companyId   String
  workspaceId String
  title       String
  type        String
  referenceId String?
  status      String            @default("published")
  sourcePath  String?
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  embeddings  EmbeddingRecord[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([companyId])
  @@index([workspaceId])
}

model EmbeddingRecord {
  id          String            @id @default(cuid())
  knowledgeId String
  companyId   String
  chunkText   String
  vectorJson  Json
  knowledge   KnowledgeDocument @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@index([companyId])
  @@index([knowledgeId])
}

model Conversation {
  id          String    @id @default(cuid())
  companyId   String
  workspaceId String
  userId      String?
  title       String?
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([workspaceId])
  @@index([userId])
}

model CompanyModule {
  id          String    @id @default(cuid())
  companyId   String
  workspaceId String
  moduleName  String
  status      String    @default("installed")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, moduleName])
  @@index([companyId])
  @@index([workspaceId])
}

model SopRevision {
  id          String    @id @default(cuid())
  workspaceId String
  referenceId String
  title       String
  revision    String
  summary     String
  status      String    @default("pending_approval")
  submitterId String?
  aiReview    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submitter   Employee? @relation("SopSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, status])
}

model EngineeringReport {
  id            String    @id @default(cuid())
  workspaceId   String
  issueId       String?
  title         String
  content       String
  reportNumber  String?
  version       Int       @default(1)
  sections      Json?
  machineCode   String?
  status        String    @default("draft")
  authorId      String?
  approvedById  String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issue         Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  author        Employee? @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  approvedBy    Employee? @relation("ReportApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, reportNumber])
}

model LessonLearned {
  id          String    @id @default(cuid())
  workspaceId String
  issueId     String?
  title       String
  content     String
  authorId    String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issue       Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  author      Employee? @relation("LessonAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model CustomerComplaint {
  id              String    @id @default(cuid())
  workspaceId     String
  complaintNumber String
  customerName    String
  product         String
  priority        String    @default("medium")
  status          String    @default("open")
  description     String?
  reportedAt      DateTime  @default(now())
  dueAt           DateTime?
  engineerId      String?
  timeline        Json?
  attachments     Json?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  engineer        Employee? @relation("ComplaintEngineer", fields: [engineerId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, complaintNumber])
}

model OperatorChecklistRun {
  id           String    @id @default(cuid())
  workspaceId  String
  line         String
  shift        String
  targetOutput Int
  progress     Int       @default(0)
  items        Json
  runDate      DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedAt    DateTime  @updatedAt

  @@index([workspaceId, runDate])
}

model MemoryRecord {
  id          String    @id @default(cuid())
  workspaceId String
  scope       String
  content     String
  tags        String[]  @default([])
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, scope])
}

model AgentAction {
  id          String    @id @default(cuid())
  workspaceId String
  toolName    String
  input       Json
  output      Json
  status      String    @default("completed")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
}

model BusinessRule {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  category    String
  metric      String
  operator    String
  threshold   Float?
  severity    String    @default("critical")
  enabled     Boolean   @default(true)
  description String?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, enabled])
}
