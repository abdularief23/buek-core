# Salin ke .env dan isi API key Anda
# Dapatkan di: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_api_key_here

# Model: veo-3.1-fast-generate-preview (lebih cepat & murah)
#        veo-3.1-generate-preview (kualitas lebih tinggi)
VEO_MODEL=veo-3.1-fast-generate-preview

# Output folder
OUTPUT_DIR=./output
