# === Mode: pilih salah satu ===
# Vertex AI (disarankan — cocok kalau API key diblokir organisasi)
USE_VERTEX_AI=true

# Project GCP Anda (dari screenshot Logs Explorer)
GOOGLE_CLOUD_PROJECT=project-c5cf1cf2-7957-4efb-a33
GOOGLE_CLOUD_LOCATION=us-central1

# Bucket GCS untuk output video (buat dulu di Cloud Storage)
# GCS_OUTPUT_URI=gs://buek-core-video-output/scenes

# === Mode Gemini API (opsional, jika punya API key AIza...) ===
# USE_VERTEX_AI=false
# GEMINI_API_KEY=your_api_key_here

# Model Vertex: veo-3.1-lite-generate-preview (paling murah)
#              veo-3.1-fast-generate-preview
#              veo-3.1-generate-001
VEO_MODEL=veo-3.1-lite-generate-preview

OUTPUT_DIR=./output
